# Database Configuration (PostgreSQL)
# Obtain this from your Supabase project settings
DATABASE_URL="postgresql://postgres:password@localhost:5432/pulsewatch"

# Auth / JWT
# Secure random strings used to sign JSON Web Tokens
JWT_SECRET="your-super-secret-access-key-here"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-here"

# API Configuration
# Port for the Express server to listen on
PORT=3000
# Environment: 'development' or 'production'
NODE_ENV="development"
# URL where the frontend web application is hosted
FRONTEND_URL="http://localhost:5173"

# Frontend Configuration
# URL where the backend API is hosted (used by the Vite React app)
VITE_API_URL="http://localhost:3000/api"

# Email Configuration (Nodemailer / SMTP)
# SMTP credentials for sending incident alerts and invites
SMTP_HOST="smtp.example.com"
SMTP_PORT=465
SMTP_USER="user"
SMTP_PASS="password"
SMTP_FROM="noreply@pulsewatch.app"
